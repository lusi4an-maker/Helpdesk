@using Helpdesk.Web.Dtos;
@using Helpdesk.Web.Services;
@inject IUsuarioService usuarioService;
@inject MudBlazor.ISnackbar snackbar;


<MudDialog>
    <TitleContent>
        Editar Usuario
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="IsValid">
            <MudTextField T="string" Label="Nombre" @bind-Value="dto.Nombre" Required="true" RequiredError="Ingrese el nombre de usuario"></MudTextField>
            <MudTextField T="string" Label="NombrePila" @bind-Value="dto.NombrePila" Required="true" RequiredError="Ingrese el nombre del usuario"></MudTextField>
            <MudTextField T="string" Label="ApellidoPila" @bind-Value="dto.ApellidoPila" Required="true" RequiredError="Ingrese el apellido del usuario"></MudTextField>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary">Editar</MudButton>
    </DialogActions>
</MudDialog>


@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public UsuarioDto usuario { get; set; } = new();

    private MudForm form;
    private bool IsValid;
    private PutUsuarioDto dto;

    protected override void OnInitialized()
    {
        dto = new PutUsuarioDto { Nombre = usuario.Nombre, NombrePila = usuario.NombrePila, ApellidoPila = usuario.ApellidoPila };
    }
    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (IsValid)
        {
            var id = usuario.Id;

            var hasEdited = await usuarioService.UpdateUsuarioAsync(id, dto);
            if (!hasEdited.Exito)
            {
                snackbar.Add(hasEdited.Error ?? "Se ha producido un error, intente de nuevo", Severity.Error);
            }
            else
            {
                var edit = new UsuarioDto
                    {
                        Id = usuario.Id,
                        Nombre = dto.Nombre,
                        Email = usuario.Email,
                        NombrePila = dto.NombrePila,
                        ApellidoPila = dto.ApellidoPila,
                        Rol = usuario.Rol,
                        Estado = usuario.Estado
                    };
                MudDialog.Close(DialogResult.Ok(edit));
                snackbar.Add("Usuario editado!", Severity.Info);
            }
        }
    }

}
