@using Helpdesk.Web.Dtos;
@using Helpdesk.Web.Services;
@inject ITicketService TicketService;
@inject MudBlazor.ISnackbar snackbar;


<MudDialog>
    <TitleContent>
        Nuevo Ticket
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="IsValid">
            <MudText>Titulo:</MudText>
            <MudTextField T="string" Label="Titulo" @bind-Value="dto.Titulo" Required="true" RequiredError="Ingrese un titulo" />
                <MudText>Descripcion:</MudText>
            <MudTextField T="string" Label="Descripcion" @bind-Value="dto.Descripcion" Required="true" RequiredError="Ingrese la descripcion del ticket" />
        </MudForm>
    </DialogContent>
        
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary">Crear</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm form;
    private bool IsValid;
    private CrearTicketDto dto = new();

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (IsValid)
        {
            var created = await TicketService.CreateTicketAsync(dto);
            if (created is null)
            {
                snackbar.Add("Se ha producido un error, intente de nuevo", Severity.Error);
            } 
            else
            {
                MudDialog.Close();
            }
        }
    }
}
