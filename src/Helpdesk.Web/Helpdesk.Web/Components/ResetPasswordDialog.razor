@using Helpdesk.Web.Dtos;
@using Helpdesk.Web.Services;
@inject IUsuarioService usuarioService;
@inject MudBlazor.ISnackbar snackbar;


<MudDialog>
    <TitleContent>
        Atencion!
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="IsValid">
            <MudText Typo="Typo.h6">Reiniciaras la contraseña de: @usuario.Nombre</MudText>
            <MudTextField T="string" Label="Contraseña" @bind-Value="dto.NewPassword" Required="true" RequiredError="Ingrese la nueva contraseña del usuario" 
                          InputType="InputType.Password"/>
            <MudTextField T="string" Label="Contraseña" @bind-Value="confirmPassword" Required="true" RequiredError="Confirme la contraseña" InputType="InputType.Password"
                          Validation="@(new Func<string, string>(x => x == dto.NewPassword ? null : "Las contraseñas no coinciden"))" />
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary">Reiniciar Contraseña</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public UsuarioDto usuario { get; set; } = new();

    private MudForm form;
    private bool IsValid;
    private ResetPasswordDto dto = new();
    private string? confirmPassword;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (IsValid)
        {
            var id = usuario.Id;
            var reseted = await usuarioService.ResetPasswordUsuarioAsync(id, dto);
            if (!reseted)
            {
                snackbar.Add("Se ha producido un error, intente de nuevo", Severity.Error);
            }
            else
            {
                MudDialog.Close(DialogResult.Ok(true));
                snackbar.Add("Contraseña reiniciada!", Severity.Info);
            }
        }
    }
}
