@using Helpdesk.Web.Dtos
@using Helpdesk.Web.Services
@inject ITicketService ticketService
@inject ISnackbar snackbar
@inject IUsuarioService usuarioService

<MudDialog>
    <TitleContent>
        Asignar a un agente
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="IsValid">
            <MudText Typo="Typo.h6">El ticket N° @ticket.Id sera asignado a:</MudText>
            <MudSelect T="int?" @bind-Value="dto.AgenteId" Label="Agente">
                <MudSelectItem T="int?" Value="@((int?)null)">Sin asignar</MudSelectItem>
                @foreach (var agente in agentes ?? [])
                {
                    <MudSelectItem T="int?" Value="@agente.Id">@agente.NombrePila @agente.ApellidoPila</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary">Editar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public TicketDto ticket { get; set; } = new();

    private MudForm form;
    private bool IsValid;

    private UsuarioDto[]? agentes;
    private AsignarTicketDto dto ;

    protected override async Task OnInitializedAsync()
    {
        dto = new AsignarTicketDto { AgenteId = ticket.AgenteAsignadoId };
        agentes = await usuarioService.GetUsuariosAsignablesAsync();
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.ValidateAsync();
        if (IsValid)
        {
            var id = ticket.Id;

            ResultadoApi assigned = await ticketService.AssignTicketAsync(id, dto);
            if (!assigned.Exito)
            {
                snackbar.Add(assigned.Error ?? "Se ha producido un error, intente de nuevo", Severity.Error);
            }
            else
            {
                ticket.AgenteAsignadoId = dto.AgenteId;
                MudDialog.Close(DialogResult.Ok(true));
                snackbar.Add("Usuario Asignado!", Severity.Info);
            }
        }
    }
}
