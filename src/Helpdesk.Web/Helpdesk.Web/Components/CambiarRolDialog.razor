@using Helpdesk.Web.Dtos
@using Helpdesk.Web.Models
@using Helpdesk.Web.Services
@inject ISnackbar snackbar
@inject IUsuarioService usuarioService

<MudDialog>
    <TitleContent>
        Cambiar rol del usuario
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="IsValid">
            <MudText Typo="Typo.h6">El rol nuevo de @usuario.Nombre</MudText>
            <MudSelect T="RolUsuario" Label="Rol" @bind-Value="dto.RolUsuario" Required="true" RequiredError="Debe asignar un rol al usuario">
                @foreach (var rol in Enum.GetValues<RolUsuario>())
                {
                    <MudSelectItem T="RolUsuario" Value="rol">@rol</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary">Editar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;
    private MudForm form;
    private bool IsValid;

    [Parameter]
    public UsuarioDto usuario { get; set; } = new();
    private ActualizarRolDto dto;

    protected override void OnInitialized()
    {
        dto = new ActualizarRolDto { RolUsuario = usuario.Rol };
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        //Espero a que se valide el formuladio
        await form.ValidateAsync();
        if (IsValid)
        {
            var id = usuario.Id;
            var result = await usuarioService.UpdateUsuarioRolAsync(id, dto);
            if (!result.Exito)
            {
                snackbar.Add(result.Error ?? "No se pudo modificar el rol, verifique.", Severity.Warning);
            }
            else
            {
                usuario.Rol = dto.RolUsuario;
                MudDialog.Close(DialogResult.Ok(true));
                snackbar.Add("Se ha modifcado correctamente el rol", Severity.Info);
            }
        }
    }

}
