@page "/tickets"
@using Helpdesk.Web.Services;
@using Helpdesk.Web.Dtos;
@using Helpdesk.Web.Components;
@using Helpdesk.Web.Models;
@using Microsoft.AspNetCore.Authorization;
@using Helpdesk.Web.Helpers;
@using Microsoft.AspNetCore.Components.Authorization

@inject ITicketService ticketService;
@inject IDialogService dialogService;
@inject ISnackbar snackbar;
@inject NavigationManager navigationManager;
@inject ILocalStorageService storage;

@attribute [Authorize]
    
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pb-3">
    <MudText Typo="Typo.h5">Tickets</MudText>
    @*Filtro de busqueda*@
    <MudTextField T="string" 
                    @bind-Value="busqueda" 
                    Immediate="true" 
                    Placeholder="Buscar por titulo.." 
                    Adornment="Adornment.Start" 
                    AdornmentIcon="@Icons.Material.Filled.Search" 
                    Margin="Margin.Dense" />
    
    @*Filtro estado de ticket*@
    <MudSelect T="EstadoTicket?"
               @bind-Value="estadoTicket"
                Placeholder="Todos los estados"
                Margin="Margin.Dense">
        
        <MudSelectItem T="EstadoTicket?" Value="null">Todos los estados</MudSelectItem>
        @foreach (var estado in Enum.GetValues<EstadoTicket>())
        {
            <MudSelectItem T="EstadoTicket?" Value="estado">@estado</MudSelectItem>
        }
    </MudSelect>

    @*Filtro de agentes*@
        <MudSelect T="int?"
                    @bind-Value="agenteId"
                    Placeholder="Todos los agentes">
                    <MudSelectItem T="int?" Value="null">Todos los agentes</MudSelectItem>
            @foreach (var agente in AgentesAsignados)
            {
                <MudSelectItem T="int?" Value="agente.AgenteAsignadoId">@agente.NombreAgente</MudSelectItem>
            }
        </MudSelect>

    <MudStack Row="true">
        <MudToggleGroup T="VistasTickets"
                        Value="vista"
                        ValueChanged="ChangeViewAsync">
            <MudToggleItem Value="VistasTickets.Tabla" Text="Tabla" />
            <MudToggleItem Value="VistasTickets.Tarjetas" Text="Tarjetas" />
        </MudToggleGroup>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenDialogAsync">
            Crear Ticket
        </MudButton>
    </MudStack>
</MudStack>

@if (vista == VistasTickets.Tabla) @*VISTA DE TABLA*@
{
        <MudTable T="TicketDto" Items="TicketsFiltrados" Hover="true" Bordered="true" Loading="tickets is null" OnRowClick="SelectedRow" >
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.Id)">ID</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.Titulo)">Titulo</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.Descripcion)">Descripcion</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.FechaCreacion)">Fecha de Creacion</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.NombreCreador)">Autor</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.NombreAgente)">Asignado a</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.Estado)">Estado</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<TicketDto, object>(x => x.Prioridad)">Prioridad</MudTableSortLabel></MudTh>
        </HeaderContent>
        <RowTemplate >
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Titulo">@context.Titulo</MudTd>
            <MudTd DataLabel="Descripcion">@context.Descripcion</MudTd>
            <MudTd DataLabel="Fecha de Creacion">@context.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd DataLabel="Autor">@context.NombreCreador</MudTd>
            <MudTd DataLabel="Asignado a">@(context.NombreAgente ?? "Sin asignar")</MudTd>
            <MudTd DataLabel="Estado">
                    <MudChip T="EstadoTicket">@context.Estado</MudChip>
            </MudTd>
            <MudTd DataLabel="Prioridad">
                <MudStack Row="true">
                    <MudIcon Icon="@Icons.Material.Filled.Circle" Color="@context.Prioridad.GetColor()" />
                    <MudText>@context.Prioridad</MudText>
                </MudStack>
            </MudTd>
            <MudTd @onclick:stopPropagation="true">
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                Color="Color.Secondary"
                OnClick="@(() => ShowUpdateDialogAsync(context))"/>
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                Color="Color.Error"
                OnClick="@(() => ShowDeleteDialogAsync(context.Id))" />
            </MudTd>
        </RowTemplate>
        <PagerContent> 
            <MudTablePager PageSizeOptions="new int[] {5, 10, 25}"/>
        </PagerContent>
    </MudTable>
}
else @*VISTA DE CARDS/TARJETAS*@
{
    @*Si esta cargando se queda en skeleton view*@
    @if (tickets is null)
    {
        <MudSkeleton />
    }
    else 
    {
        <MudGrid>
            @foreach (var ticket in TicketsFiltrados)
            {
                <MudItem xs="12" md="3">
                    <MudCard @onclick="@(() => NavigateToDetail(ticket.Id))" Style="cursor:pointer">
                        <MudCardContent>
                            @*Muestro el titulo y estado en la misma fila*@
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.subtitle1">@ticket.Titulo</MudText>
                                <MudChip T="EstadoTicket">@ticket.Estado</MudChip>
                            </MudStack>
                            @*Si la descripcion es mas de 80 caracteres, se agregan '...'*@
                            <MudText Typo="Typo.body2">
                                @(ticket.Descripcion.Length > 80 ? ticket.Descripcion[..80] + "..." : ticket.Descripcion)
                            </MudText>
                            @*Chip de prioridad*@
                            <MudStack Row="true">
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Color="@ticket.Prioridad.GetColor()" />
                                <MudText>@ticket.Prioridad</MudText>
                            </MudStack>
                            <MudDivider Class="my-2"/>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Row="true">
                                    <MudAvatar Size="Size.Small">@InicialHelper.InicialesHelper(ticket.NombreAgente)</MudAvatar>
                                    <MudText>@(ticket.NombreAgente ?? "Sin Asignar")</MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption">@ticket.FechaCreacion.ToString("dd/MM/yyyy")</MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    private TicketDto[]? tickets;
    private VistasTickets vista = VistasTickets.Tabla;

    //Variables del buscador y filtros
    private string? busqueda;
    private EstadoTicket? estadoTicket;
    private int? agenteId;


    protected override async Task OnInitializedAsync()
    {
        tickets = await ticketService.GetTicketsAsync();
        var guardada = await storage.GetItemAsync("vistaTickets");
        if (!string.IsNullOrEmpty(guardada) && Enum.TryParse<VistasTickets>(guardada, out var v))
        {
            vista = v;
        }
    }

    private async Task OpenDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = await dialogService.ShowAsync<CrearTicketDialog>("Nuevo Ticket", options);

        var result = await dialog.Result;
        if (result?.Data is TicketDto nuevo)
        {
            tickets = tickets?.Append(nuevo).ToArray();
        }
    }

    private async Task ShowDeleteDialogAsync(int id)
    {
        bool? result = await dialogService.ShowMessageBoxAsync(
        title: "Atencion!",
        message: "Esta seguro que quiere borrar el ticket?",
        yesText: "Borrar",
        cancelText: "Cancel"
        );

        if (result == true)
        {
            var ok = await ticketService.DeleteTicketAsync(id);
            if (ok == true) 
            { 
                tickets = tickets?.Where(t => t.Id != id).ToArray(); 
            } 
            else 
            { 
                snackbar.Add("No se pudo eliminar el ticket", Severity.Error);
            }

        }
    }

    private async Task ShowUpdateDialogAsync(TicketDto ticketAEditar)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<PutTicketDialog> { { x => x.ticket, ticketAEditar } };
        var dialog = await dialogService.ShowAsync<PutTicketDialog>("Editar ticket", parameters, options);

        var result = await dialog.Result;
        if (result?.Data is TicketDto edit)
        {
            tickets = tickets?.Select(t => t.Id == edit.Id ? edit : t).ToArray();
        }

    }

    //Redirect a la pagina del detalle en ambas vistas
    private void SelectedRow(TableRowClickEventArgs<TicketDto> e)
    {
        navigationManager.NavigateTo($"/tickets/{e.Item!.Id}");
    }
    private void NavigateToDetail(int ticketId)
    {
        navigationManager.NavigateTo($"tickets/{ticketId}");
    }

    //Muestro el dialogo de asignar agente
    private async Task ShowAssignDialogAsync(TicketDto ticketAAsignar)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<AsignarAgenteDialog> { { x => x.ticket, ticketAAsignar } };
        var dialog = await dialogService.ShowAsync<AsignarAgenteDialog>("Asignar agente", parameters, options);

        await dialog.Result;

    }

    //Handler para guardar el estado de vista 
    private async Task ChangeViewAsync(VistasTickets nueva)
    {
        vista = nueva;
        await storage.SetItemAsync("vistaTickets", nueva.ToString());
    }

    //Propiedad para filtros
    private IEnumerable<TicketDto> TicketsFiltrados =>
        (tickets ?? [])
            .Where(t => string.IsNullOrWhiteSpace(busqueda) || t.Titulo.Contains(busqueda!, StringComparison.OrdinalIgnoreCase))
            .Where(t => estadoTicket is null || t.Estado == estadoTicket)
            .Where(t => agenteId is null || t.AgenteAsignadoId == agenteId);


    //Propiedad para agentes ya asignados
    private IEnumerable<TicketDto> AgentesAsignados =>
        (tickets ?? [])
            .Where(t => t.AgenteAsignadoId is not null)
            .DistinctBy(t => t.AgenteAsignadoId);
}
            