@using Helpdesk.Web.Components;
@using Helpdesk.Web.Dtos;
@using Helpdesk.Web.Services;
@using Microsoft.AspNetCore.Authorization

@inject IUsuarioService usuarioService
@inject IDialogService dialogService;
@inject ISnackbar snackbar;

@page "/usuarios"
@attribute [Authorize(Roles = "Administrador,Gerente")]

<MudTable T="UsuarioDto" Items="users ?? []" Hover="true" Bordered="true" Loading="users is null" >
    <ToolBarContent>
        <MudText Typo="Typo.h6">Usuarios</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenDialogAsync">
            Usuario
        </MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.Id)">Id</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.Nombre)">Usuario</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.Email)">Email</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.NombrePila)">NombrePila</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.ApellidoPila)">ApellidoPila</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.Rol)">Rol</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<UsuarioDto, object>(u => u.Estado)">Estado</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Id">@context.Id</MudTd>
        <MudTd DataLabel="Usuario">@context.Nombre</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Nombre Pila">@context.NombrePila</MudTd>
        <MudTd DataLabel="Apellido Pila">@context.ApellidoPila</MudTd>
        <MudTd DataLabel="Rol">@context.Rol</MudTd>
        <MudTd DataLabel="Estado">@context.Estado</MudTd>
        <MudTd @onclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings"
                           Color="Color.Secondary"
                           OnClick="@(() => ShowCambiarRolDialogAsync(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Key"
                           Color="Color.Warning"
                           OnClick="@(() => ShowResetPasswordDialogAsync(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Color="Color.Secondary"
                           OnClick="@(() => ShowUpdateDialogAsync(context))"/>
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           OnClick="@(() => ShowDeleteDialogAsync(context.Id))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] {5, 10, 25}"/>
    </PagerContent>
</MudTable>


@code {
    private UsuarioDto[]? users;


    private async Task OpenDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };

        var dialog = await dialogService.ShowAsync<CrearUsuarioDialog>("Nuevo Usuario", options);

        var result = await dialog.Result;
        if (result?.Data is UsuarioDto nuevo)
        {
            users = users?.Append(nuevo).ToArray();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        users = await usuarioService.GetUsuariosAsync();
    }

    private async Task ShowUpdateDialogAsync(UsuarioDto usuarioAEditar)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<PutUsuarioDialog> { { x => x.usuario, usuarioAEditar } };
        var dialog = await dialogService.ShowAsync<PutUsuarioDialog>("Editar usuario", parameters, options);

        var result = await dialog.Result;
        if (result?.Data is UsuarioDto edit)
        {
            //Ejecuto el update inline para actualizar la vista
            users = users?.Select(u => u.Id == edit.Id ? edit : u).ToArray();
        }

    }

    private async Task ShowDeleteDialogAsync(int id)
    {
        bool? result = await dialogService.ShowMessageBoxAsync(
        title: "Atencion!",
        message: "Esta seguro que quiere borrar el usuario?",
        yesText: "Borrar",
        cancelText: "Cancel"
        );

        if (result == true)
        {
            var ok = await usuarioService.DeleteUsuarioAsync(id);
            if (ok == true)
            {
                users = users?.Where(u => u.Id != id).ToArray();
            }
            else
            {
                snackbar.Add("No se pudo eliminar el usuario", Severity.Error);
            }

        }
    }

    private async Task ShowResetPasswordDialogAsync(UsuarioDto usuarioAEditar)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<ResetPasswordDialog> { { x => x.usuario, usuarioAEditar } };
        var dialog = await dialogService.ShowAsync<ResetPasswordDialog>("Reiniciar contraseña", parameters, options);

        var result = await dialog.Result;
        if (result?.Data is true)
        {
            snackbar.Add("Se ha reiniciado la contraseña con exito!", Severity.Success);
        }
    }


    //Muestro el dialog de cambiar rol
    private async Task ShowCambiarRolDialogAsync(UsuarioDto usuarioAEditar)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters<CambiarRolDialog> { { x => x.usuario, usuarioAEditar } };

        var dialog = await dialogService.ShowAsync<CambiarRolDialog>("Cambiar rol", parameters, options);

        await dialog.Result;
    }
}
